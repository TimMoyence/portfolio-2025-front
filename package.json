{
  "name": "portfolio-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prepare": "husky",
    "start": "ng serve",
    "build": "CI=true ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "test:cov": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox --code-coverage",
    "lint": "eslint . --ext .ts,.html,.js",
    "lint:fix": "eslint . --ext .ts,.html,.js --fix",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\" \"*.{json,js,cjs,md,yml,yaml}\" \".github/**/*.{md,yml,yaml}\" \"docs/**/*.md\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ci:check": "npm run lint && npm run format:check && npm run typecheck && npm run test:ci && npm run build",
    "serve:ssr:portfolio-app": "node dist/portfolio-app/server/fr/server.mjs",
    "extract-i18n": "ng extract-i18n --output-path src/locale --format xlf",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:visual": "npx playwright test e2e/visual-regression.spec.ts",
    "test:visual:update": "npx playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert"
  },
  "lint-staged": {
    "*.{ts,js,html}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{ts,js,html,scss,css,json,md,cjs,yml,yaml}": [
      "prettier --write"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.20",
    "@angular/common": "^19.2.20",
    "@angular/compiler": "^19.2.20",
    "@angular/core": "^19.2.20",
    "@angular/forms": "^19.2.20",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^19.2.20",
    "@angular/platform-server": "^19.2.20",
    "@angular/router": "^19.2.20",
    "@angular/ssr": "^19.2.23",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "express": "^4.18.2",
    "hammerjs": "^2.0.8",
    "leaflet": "^1.9.4",
    "ngx-extended-pdf-viewer": "^23.0.0-alpha.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.23",
    "@angular/cli": "^19.2.23",
    "@angular/compiler-cli": "^19.2.20",
    "@angular/localize": "^19.2.20",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^18.18.0",
    "angular-eslint": "^19.8.1",
    "autoprefixer": "^10.4.14",
    "baseline-browser-mapping": "^2.9.14",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.21",
    "prettier": "^3.8.0",
    "tailwindcss": "^3.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.57.1"
  }
}
